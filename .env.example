# Copy to .env and fill in values
# Next.js loads .env, .env.local, .env.development, .env.production

# Required - MongoDB connection
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ngo-db"
# Or local: mongodb://localhost:27017/ngo-db

# Generate with: openssl rand -base64 32
JWT_SECRET="super_secure_secret"

# Razorpay (optional - required for donations)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# SMTP (optional - required for volunteer/donation emails)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Optional
# SMTP_FROM=""  # from address (defaults to SMTP_USER)
# ORG_NAME=""   # organization name for emails
